# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# === DATABASE ===
DATABASE_URL="postgresql://user:password@localhost:5432/dappdrop"

# === BLOCKCHAIN ===
NEXT_PUBLIC_CAMPAIGN_FACTORY_CONTRACT="0x..."
NEXT_PUBLIC_SEPOLIA_RPC_URL="https://rpc.sepolia.org"

# === AI SERVICE ===
GEMINI_API_KEY="your-gemini-api-key"

# === AUTHENTICATION ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# === DISCORD INTEGRATION ===
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_BOT_TOKEN="your-discord-bot-token"

# === TELEGRAM INTEGRATION ===
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_BOT_USERNAME="your-bot-username"

# === HUMANITY PROTOCOL (v2 - OAuth SDK) ===
# Register your app at https://developers.humanity.org/ to get credentials
NEXT_PUBLIC_HUMANITY_CLIENT_ID="your-client-id"
NEXT_PUBLIC_HUMANITY_REDIRECT_URI="http://localhost:3000/humanity-callback"
NEXT_PUBLIC_HUMANITY_ENVIRONMENT="sandbox"
# Portal URL for user reference
NEXT_PUBLIC_HUMANITY_PORTAL_URL="https://testnet.humanity.org"

# === UPLOADTHING ===
# Get your API keys from https://uploadthing.com/dashboard
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID=g159p6itzj
